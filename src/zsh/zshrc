[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion


if [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then . "$HOME/.nix-profile/etc/profile.d/nix.sh"; fi # added by Nix installer

# source <(kubeclt completion bash)

# Generated for envman. Do not edit.
[ -s "$HOME/.config/envman/load.sh" ] && source "$HOME/.config/envman/load.sh"

# opencode
[ -d "$HOME/.opencode/bin" ] && export PATH="$HOME/.opencode/bin:$PATH"

# --- History search (omarchy-style) ---
# fzf: Ctrl+R fuzzy history (deduped, newest first, Enter pastes to edit),
#      Ctrl+T fuzzy file picker, Alt+C fuzzy cd, '**<Tab>' fuzzy completion
# Integration scripts are vendored in this repo (src/zsh/fzf/), resolved
# relative to this file's real location (works wherever the repo is cloned).
if command -v fzf >/dev/null 2>&1; then
  _dotfiles_zsh_dir=${${(%):-%N}:A:h}
  source "$_dotfiles_zsh_dir/fzf/key-bindings.zsh"
  source "$_dotfiles_zsh_dir/fzf/completion.zsh"
  unset _dotfiles_zsh_dir
fi

# Up/Down: prefix history search (type 'git' + Up cycles 'git ...' commands)
for keymap in viins vicmd; do
  bindkey -M $keymap '^[[A' history-beginning-search-backward
  bindkey -M $keymap '^[OA' history-beginning-search-backward
  bindkey -M $keymap '^[[B' history-beginning-search-forward
  bindkey -M $keymap '^[OB' history-beginning-search-forward
done
